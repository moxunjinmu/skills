# 智谱 ASR 环境变量配置

# 必需：智谱 API 密钥
# 从 https://open.bigmodel.cn/ 获取
# ZHIPU_API_KEY=your_api_key_here

# 可选：模型名称（默认：glm-asr-2512）
# ZHIPU_MODEL=glm-asr-2512

# 可选：最大重试次数（默认：3）
# ZHIPU_MAX_RETRIES=3

# 可选：默认热词表（逗号分隔，最多 100 个词）
# ZHIPU_HOTWORDS=智谱,AI,语音识别,自然语言处理

# 注意事项：
# 1. 推荐在 ~/.openclaw/openclaw.json 的 skills.zhipu-asr.apiKey 中配置 API Key
# 2. 也可以使用 export ZHIPU_API_KEY=xxx 设置环境变量
# 3. 配置文件优先级高于环境变量
